# ============================================================
# Watcher MK1 — Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# ── AWS Bedrock (AI Reasoning Engine) ──────────────────────
# Watcher server account — where Bedrock runs
# On EC2: remove these lines and use an instance role instead
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ── Database (PostgreSQL) ──────────────────────────────────
# Set DB_ENABLED=true for production. false = in-memory (dev only).
DB_ENABLED=false
DB_HOST=localhost
DB_PORT=5432
DB_NAME=watcher_mk1
DB_USER=watcher
DB_PASSWORD=
DB_SSL=false
DB_POOL_MAX=20

# ── Server ──────────────────────────────────────────────────
PORT=4000
CORS_ORIGIN=http://localhost:5173
NODE_ENV=development

# ── Authentication ──────────────────────────────────────────
# Set AUTH_ENABLED=true for production. false = dev mode (no login required).
AUTH_ENABLED=false
JWT_SECRET=change-this-to-a-64-char-random-string-in-production
JWT_EXPIRES_IN=24h
DEFAULT_TENANT_ID=tenant-001

# ── Notifications ───────────────────────────────────────────
# Discord webhook URL for approval alerts.
# Create: Discord Server → Settings → Integrations → Webhooks → New Webhook → Copy URL
# Leave empty to disable.
DISCORD_WEBHOOK_URL=
# URL of the dashboard (used in Discord notification links)
DASHBOARD_URL=http://localhost:5173

# ── Polling ─────────────────────────────────────────────────
# How often to poll CloudTrail for new events (seconds).
# CloudTrail has a 5-15 min delivery delay so polling faster than 60s doesn't help.
POLL_INTERVAL_SECONDS=60
# How far back to look on first connector registration (minutes).
# Default: 129600 = 90 days (CloudTrail maximum).
# Set to 120 for faster testing (2 hours).
# POLL_LOOKBACK_MINUTES=120

# ── Supermemory (Semantic Memory Layer) ─────────────────────
# Local Supermemory server URL. Start with: npx supermemory@latest local
SUPERMEMORY_BASE_URL=http://localhost:6767
# LLM provider for embeddings: openai | anthropic | ollama
SUPERMEMORY_LLM_PROVIDER=ollama
# API key for the configured LLM provider
SUPERMEMORY_LLM_API_KEY=
# Model name for embeddings (optional, uses provider default if empty)
SUPERMEMORY_LLM_MODEL=
# Max number of semantic search results returned
SUPERMEMORY_SEARCH_LIMIT=10
# Per-operation timeout in milliseconds
SUPERMEMORY_TIMEOUT_MS=5000
# Reconnection interval (ms) when in fallback mode
SUPERMEMORY_RECONNECT_INTERVAL_MS=30000
# Minimum similarity score (0-1) for search results
SUPERMEMORY_SIMILARITY_THRESHOLD=0.5
# Max queued write operations during fallback mode
SUPERMEMORY_WRITE_QUEUE_MAX=1000
